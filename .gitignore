# pyenv
#   For a library or package, you might want to ignore these files since the Python version
#   is generally handled by the user. In applications, you may want to check them in.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to check Pipfile.lock into version control.
#   However, in case of collaboration, if you are having trouble with it, you can uncomment
#   the line below.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to check poetry.lock into version control.
#   poetry.lock

# pdm
#   Similar to Pipfile.lock, it is generally recommended to check pdm.lock into version control.
#pdm.lock
#   pdm build plugins may create files here
.pdm-build/

# PEP 582; used by e.g. github.com/fannheyward/coc-pyright
__pypackages__/

